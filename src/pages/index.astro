---
import { getCollection } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import FormattedDate from "../components/FormattedDate.astro";
import Header from "../components/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";

const posts = (await getCollection("blog")).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const recentPosts = posts.slice(0, 3);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.hero {
				padding: 2em 0 1em;
			}
			.hero h1 {
				margin-bottom: 0.25em;
			}
			.hero .subtitle {
				font-size: 1.1em;
				color: rgb(var(--gray));
				line-height: 1.6;
				max-width: 600px;
			}
			.intro {
				margin-top: 1.5em;
				margin-bottom: 2.5em;
				padding-bottom: 2em;
				border-bottom: 1px solid rgb(var(--gray-light));
			}
			.intro p {
				color: rgb(var(--gray-dark));
			}
			.section-title {
				font-size: 1.5em;
				margin-bottom: 1em;
			}
			.post-list {
				list-style: none;
				padding: 0;
				margin: 0 0 3em;
			}
			.post-list li {
				padding: 1.25em 0;
				border-bottom: 1px solid rgb(var(--gray-light));
			}
			.post-list li:last-child {
				border-bottom: none;
			}
			.post-list a {
				text-decoration: none;
				color: inherit;
				display: block;
			}
			.post-list a:hover .post-title {
				color: var(--accent);
			}
			.post-title {
				font-size: 1.25em;
				font-weight: 700;
				margin: 0 0 0.25em;
				color: rgb(var(--black));
				line-height: 1.3;
			}
			.post-meta {
				font-size: 0.85em;
				color: rgb(var(--gray));
				margin-bottom: 0.35em;
			}
			.post-meta .category {
				background: rgb(var(--gray-light));
				padding: 0.15em 0.5em;
				border-radius: 3px;
				font-size: 0.9em;
				margin-left: 0.5em;
			}
			.post-description {
				margin: 0;
				color: rgb(var(--gray-dark));
				font-size: 0.95em;
			}
			.category-grid {
				display: flex;
				gap: 1em;
				flex-wrap: wrap;
				margin-bottom: 2em;
			}
			.category-card {
				flex: 1;
				min-width: 150px;
				padding: 1.5em 1.25em;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 6px;
				text-decoration: none;
				color: rgb(var(--gray-dark));
				text-align: center;
				transition: border-color 0.2s ease;
			}
			.category-card:hover {
				border-color: var(--accent);
				color: var(--accent);
			}
			.category-card h3 {
				margin: 0;
				font-size: 1.15em;
			}
			.view-all {
				display: inline-block;
				margin-top: 0.5em;
				font-size: 0.95em;
				color: var(--accent);
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<h1>Yogi Writes</h1>
				<p class="subtitle">
					I write stories and sketches, I love to write satire and
					absurd comedy and sometimes serious too.
				</p>
			</section>

			<section class="intro">
				<p>
					I am trying to make people laugh and think at the same time.
					It is just my hobby but I can promise that I will try and
					get better with each one. Stories can be in Hindi, English
					or Hinglish, based on my mood.
				</p>
			</section>

			<section>
				<h2 class="section-title">Recent Writing</h2>
				<ul class="post-list">
					{
						recentPosts.map((post) => (
							<li>
								<a href={`/blog/${post.id}/`}>
									<p class="post-title">{post.data.title}</p>
									<p class="post-meta">
										<FormattedDate
											date={post.data.pubDate}
										/>
										{post.data.category && (
											<span class="category">
												{post.data.category}
											</span>
										)}
									</p>
									{post.data.description && (
										<p class="post-description">
											{post.data.description}
										</p>
									)}
								</a>
							</li>
						))
					}
				</ul>
				<a class="view-all" href="/blog">View all writing &rarr;</a>
			</section>

			<section style="margin-top: 3em;">
				<h2 class="section-title">Browse By Category</h2>
				<div class="category-grid">
					<a class="category-card" href="/blog?category=Story">
						<h3>Stories</h3>
					</a>
					<a class="category-card" href="/blog?category=Sketch">
						<h3>Sketches</h3>
					</a>
					<a class="category-card" href="/blog?category=Note">
						<h3>Notes</h3>
					</a>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
